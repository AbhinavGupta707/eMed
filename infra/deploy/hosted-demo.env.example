# Non-clinical, synthetic hosted-demo profile. Store actual values in Vercel,
# never in this file. APP_BASE_URL must be the exact stable HTTPS origin.
APP_ENV=demo
APP_BASE_URL=https://replace-with-stable-demo-origin.example
# DATABASE_URL=<required server-only pooled Neon URL>
DEMO_MODE=true
# DEMO_ACCESS_SECRET=<required random server-only value, at least 16 characters>
FHIR_PROVIDER=fixture

# Complete no-key profile. Enable ElevenLabs only after its account, retention,
# residency, and agent configuration have been reviewed.
VOICE_PROVIDER=disabled
# ELEVENLABS_API_KEY=<server-only; omit while disabled>
# ELEVENLABS_AGENT_ID=<server-only; omit while disabled>
ELEVENLABS_SERVER_LOCATION=eu-residency
VOICE_SESSION_MAX_SECONDS=120
NARRATIVE_MODEL_PROVIDER=disabled

# Local finger PPG is the no-key default. VitalLens also requires explicit
# consent, proxy enablement, a server-only key, and acceptance of its US API.
OPTICAL_ASSESSMENT_PROVIDER=finger_ppg
# VITALLENS_API_KEY=<server-only; omit while finger_ppg is selected>
VITALLENS_PROXY_ENABLED=false

STORE_RAW_MEDIA=false
ENABLE_PROVIDER_TRACING=false
LOG_LEVEL=info
