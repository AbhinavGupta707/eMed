APP_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://homerounds:homerounds@localhost:5432/homerounds
DEMO_MODE=true
DEMO_ACCESS_SECRET=replace-with-a-local-demo-secret
FHIR_PROVIDER=fixture
VOICE_PROVIDER=disabled
# ELEVENLABS_API_KEY=replace-only-when-elevenlabs-is-enabled
# ELEVENLABS_AGENT_ID=replace-only-when-elevenlabs-is-enabled
ELEVENLABS_SERVER_LOCATION=global
VOICE_SESSION_MAX_SECONDS=120
NARRATIVE_MODEL_PROVIDER=disabled
INFERENCE_PROVIDER=disabled
# FIREWORKS_API_KEY=replace-only-when-fireworks-is-enabled
FIREWORKS_SELECTION_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
INFERENCE_REQUEST_TIMEOUT_MS=8000
INFERENCE_MAX_RETRIES=1
ADAPTIVE_SELECTION_ENABLED=false
MEDICATION_LABEL_AI_ENABLED=false
OPTICAL_ASSESSMENT_PROVIDER=finger_ppg
# VITALLENS_API_KEY=replace-only-when-vitallens-is-enabled
VITALLENS_PROXY_ENABLED=false
STORE_RAW_MEDIA=false
ENABLE_PROVIDER_TRACING=false
LOG_LEVEL=info
